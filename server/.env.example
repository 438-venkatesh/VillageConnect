PORT=4000
HOST=0.0.0.0
MONGODB_URI=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/villageconnect?ssl=true&authSource=admin&replicaSet=atlas-REPLICA&retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string
CORS_ORIGIN=*
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=VillageConnect <your-email@gmail.com>
# Required on Render if SMTP is blocked. Also used as fallback when email send fails.
ENABLE_STATIC_OTP=true
STATIC_OTP=123456
